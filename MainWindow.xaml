<Window x:Class="ScreenDimmer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="ScreenDimmer"
        Height="320"
        Width="480"
        MinHeight="280"
        MinWidth="400"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        WindowStyle="None"
        Background="#FF2D2D30"
        Foreground="#FFFFFFFF"
        Closing="MainWindow_OnClosing"
        StateChanged="MainWindow_OnStateChanged">
    <!-- Подэтап 2.2: хром; подэтап 2.3: переключатель темы (без анимаций) -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="40"
            CornerRadius="0"
            GlassFrameThickness="0"
            NonClientFrameEdges="None"
            ResizeBorderThickness="5"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border
        x:Name="ChromeBorder"
        BorderBrush="#FF555555"
        BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                x:Name="TitleBarBorder"
                Grid.Row="0"
                Background="#FF3C3C3C"
                MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid>
                    <TextBlock
                        x:Name="TitleBarText"
                        Margin="12,0,48,0"
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="#FFFFFFFF"
                        IsHitTestVisible="False"
                        Text="ScreenDimmer" />
                    <Button
                        x:Name="MinimizeToTrayButton"
                        Width="40"
                        Height="40"
                        HorizontalAlignment="Right"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="MinimizeToTray_OnClick"
                        Content="—"
                        Cursor="Hand"
                        FontSize="16"
                        Foreground="#FFFFFFFF"
                        ToolTip="Свернуть в трей" />
                </Grid>
            </Border>

            <ScrollViewer
                x:Name="ContentScrollViewer"
                Grid.Row="1"
                Padding="20"
                VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock
                        x:Name="HeadingTextBlock"
                        Margin="0,0,0,12"
                        FontSize="22"
                        FontWeight="Bold"
                        Foreground="#FFFFFFFF"
                        Text="ScreenDimmer"
                        TextWrapping="Wrap" />
                    <TextBlock
                        x:Name="DescTextBlock"
                        Margin="0,0,0,12"
                        FontSize="14"
                        Foreground="#FFF0F0F0"
                        LineHeight="20"
                        Text="Утилита для быстрого затемнения экрана на всех подключённых мониторах."
                        TextWrapping="Wrap" />
                    <TextBlock
                        x:Name="HotkeyTextBlock"
                        FontSize="14"
                        Foreground="#FFF0F0F0"
                        LineHeight="20"
                        Text="Горячая клавиша: F8 — включить или выключить затемнение."
                        TextWrapping="Wrap" />

                    <StackPanel Margin="0,16,0,0" Orientation="Horizontal">
                        <TextBlock
                            x:Name="ThemeLabelText"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            Foreground="#FFE0E0E0"
                            Text="Тема:" />
                        <!-- Checked не в XAML: при разборе BAML событие срабатывает до создания второго RadioButton → падение в ApplyTheme -->
                        <RadioButton
                            x:Name="ThemeDarkRadio"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Content="Тёмная"
                            Foreground="#FFE0E0E0"
                            GroupName="AppTheme"
                            IsChecked="True" />
                        <RadioButton
                            x:Name="ThemeLightRadio"
                            VerticalAlignment="Center"
                            Content="Светлая"
                            Foreground="#FFE0E0E0"
                            GroupName="AppTheme" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
